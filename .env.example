# App
APP_NAME=World Cup 2026 AI Stats
APP_ENV=development
APP_VERSION=1.21.0

# Database
POSTGRES_USER=worldcup
POSTGRES_PASSWORD=worldcup
POSTGRES_DB=worldcup
DATABASE_URL=postgresql+psycopg://worldcup:worldcup@postgres:5432/worldcup

# Dashboard
DASHBOARD_PORT=8501
BACKEND_API_URL=http://backend:8000

# Football API Provider
FOOTBALL_API_PROVIDER=api_football
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_KEY=replace_me
API_FOOTBALL_WORLD_CUP_LEAGUE_ID=1
API_FOOTBALL_SEASON=2026

# Zafronix Provider
ZAFRONIX_BASE_URL=https://api.zafronix.com/fifa/worldcup/v1
ZAFRONIX_API_KEY=replace_me
ZAFRONIX_WORLD_CUP_YEAR=2026

# Fixed-time provider sync
# Disabled by default. Enabling this starts a local provider-only scheduler.
# The scheduler waits for the next future configured slot after startup/restart.
PROVIDER_SYNC_SCHEDULER_ENABLED=false
PROVIDER_SYNC_SCHEDULE_TIMEZONE=Asia/Singapore
PROVIDER_SYNC_SCHEDULE_TIMES=03:45,09:45,12:45

# Retained for status compatibility with earlier releases.
# The runtime scheduler uses the fixed daily times above.
PROVIDER_SYNC_INTERVAL_MINUTES=30

# Dashboard freshness thresholds for the latest successful fixture sync.
FIXTURE_SYNC_FRESH_AFTER_MINUTES=60
FIXTURE_SYNC_STALE_AFTER_MINUTES=180

# Telegram
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me

# Disabled by default. Controls legacy per-fixture alerts from manual sync routes.
# /notifications/telegram/test remains an explicitly triggered operator test.
TELEGRAM_COMPLETED_MATCH_ALERTS_ENABLED=false

# Disabled by default. Controls one scheduled digest for newly completed
# fixtures detected in a scheduled provider-sync run. Empty completion sets are silent.
TELEGRAM_SCHEDULED_DIGEST_ENABLED=false

# Local Llama / Ollama
LLAMA_BASE_URL=http://host.docker.internal:11434
LLAMA_MODEL=llama3.2:1b
LLAMA_TIMEOUT_SECONDS=60

# Public URL
PUBLIC_DASHBOARD_URL=http://localhost:8000/dashboard
